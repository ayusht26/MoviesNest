---
import '../styles/global.css';
import { getTMDBStatus } from '../lib/tmdb';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  cinemaMode?: boolean;
}
const { title = 'MoviesNest', description = 'Watch movies and TV shows for free', ogImage, cinemaMode = false } = Astro.props;
const tmdbKey = import.meta.env.PUBLIC_TMDB_KEY || 'test';
const tmdbStatus = getTMDBStatus();
---
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="tmdb-status" content={tmdbKey} />
  <title>{title} | MoviesNest</title>
  <!-- OG Meta -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <script is:inline>
    // Always enforce dark theme
    document.documentElement.classList.add('dark');
  </script>
</head>
<body class={`min-h-screen bg-canvas-soft text-ink transition-colors duration-300 ${cinemaMode ? 'cinema-dark dark' : 'dark'}`}>
  <slot />

  <!-- VPN Block Warning Banner -->
  <div id="vpn-banner" class="hidden fixed bottom-4 left-4 right-4 z-50 max-w-md mx-auto">
    <div class="glass-card rounded-2xl p-4 border border-yellow-500/40 shadow-xl shadow-black/60 bg-canvas/80 backdrop-blur-md">
      <div class="flex items-start gap-3">
        <span class="text-yellow-400 text-xl">⚠️</span>
        <div class="flex-1">
          <p class="text-nest-text text-sm font-semibold">Content blocked by your ISP</p>
          <p class="text-nest-muted text-xs mt-1">Movie data can't load. Please connect to a VPN.</p>
          <a href="/blocked" class="mt-2 inline-block text-nest-accent text-xs underline underline-offset-2">
            How to fix this →
          </a>
        </div>
        <button onclick="document.getElementById('vpn-banner').classList.add('hidden')"
          class="text-nest-muted hover:text-nest-text text-sm cursor-pointer">✕</button>
      </div>
    </div>
  </div>

  <!-- TMDB Rate Limit Warning Banner -->
  <div id="rate-limit-banner" class={`${tmdbStatus.isRateLimited ? 'block' : 'hidden'} fixed bottom-4 left-4 right-4 z-50 max-w-md mx-auto`}>
    <div class="glass-card rounded-2xl p-4 border border-amber-500/40 shadow-xl shadow-black/60 bg-canvas/85 backdrop-blur-md">
      <div class="flex items-start gap-3">
        <span class="text-amber-500 text-xl animate-pulse">⏳</span>
        <div class="flex-1">
          <p class="text-nest-text text-sm font-semibold">TMDB API Rate Limit Reached</p>
          <p class="text-nest-muted text-xs mt-1">MoviesNest is currently operating in mock data fallback mode due to high request traffic.</p>
        </div>
        <button onclick="document.getElementById('rate-limit-banner').classList.add('hidden')"
          class="text-nest-muted hover:text-nest-text text-sm cursor-pointer">✕</button>
      </div>
    </div>
  </div>

  <!-- TMDB Auth Error Warning Banner -->
  <div id="auth-error-banner" class={`${tmdbStatus.isAuthError ? 'block' : 'hidden'} fixed bottom-4 left-4 right-4 z-50 max-w-md mx-auto`}>
    <div class="glass-card rounded-2xl p-4 border border-red-500/40 shadow-xl shadow-black/60 bg-canvas/85 backdrop-blur-md">
      <div class="flex items-start gap-3">
        <span class="text-red-500 text-xl animate-pulse">🔒</span>
        <div class="flex-1">
          <p class="text-nest-text text-sm font-semibold">TMDB API Key Invalid</p>
          <p class="text-nest-muted text-xs mt-1">Authentication failed. Please verify your TMDB credentials. Operating in mock fallback mode.</p>
        </div>
        <button onclick="document.getElementById('auth-error-banner').classList.add('hidden')"
          class="text-nest-muted hover:text-nest-text text-sm cursor-pointer">✕</button>
      </div>
    </div>
  </div>

  <script>
    // Client-side TMDB Status and VPN block detection
    (async () => {
      if (window.location.pathname === '/blocked') return;
      try {
        const key = document.querySelector('meta[name="tmdb-status"]')?.getAttribute('content') || '';
        if (!key || key === 'your_api_key_here') {
          return;
        }
        
        const res = await fetch('https://api.tmdb.org/3/configuration?api_key=' + key, {
          signal: AbortSignal.timeout(5000)
        });

        if (res.status === 429) {
          const banner = document.getElementById('rate-limit-banner');
          if (banner) {
            banner.classList.remove('hidden');
            banner.classList.add('block');
          }
        } else if (res.status === 401 || res.status === 403) {
          const banner = document.getElementById('auth-error-banner');
          if (banner) {
            banner.classList.remove('hidden');
            banner.classList.add('block');
          }
        }
        
        // 2. Check if the image CDN domain is reachable (crucial for cast & recommendations posters)
        await fetch('https://image.tmdb.org/t/p/w92/placeholder.jpg', {
          signal: AbortSignal.timeout(4000),
          mode: 'no-cors'
        });
      } catch (err) {
        // Network connection error / ISP block (either API domain or image CDN is blocked)
        const banner = document.getElementById('vpn-banner');
        if (banner) {
          banner.classList.remove('hidden');
          banner.classList.add('block');
        }
      }
    })();
  </script>
</body>
</html>
