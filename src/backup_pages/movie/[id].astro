---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/layout/Navbar';
import DetailHero from '../../components/detail/DetailHero';
import CastRow from '../../components/detail/CastRow';
import SimilarRow from '../../components/detail/SimilarRow';
import Footer from '../../components/layout/Footer';
import { getMovie } from '../../lib/tmdb';

const { id } = Astro.params;

let movie = null;
try {
  movie = await getMovie(id);
} catch (e) {
  console.error(`Error fetching movie ${id}:`, e);
}

// Redirect or return 404 if movie not found
if (!movie || !movie.id) {
  return new Response("Movie not found in database", { status: 404 });
}

const title = movie.title || 'Movie Details';
const backdrop = movie.backdrop_path || '';
const poster = movie.poster_path || '';
const voteAverage = movie.vote_average || 0;
const overview = movie.overview || '';
const releaseDate = movie.release_date || '';
const genres = movie.genres || [];
const runtime = movie.runtime || 0;
const tagline = movie.tagline || '';
const cast = movie.credits?.cast || [];
const similar = movie.similar?.results || [];
---

<BaseLayout title={`${title} — MoviesNest`} description={overview} ogImage={backdrop} cinemaMode={true}>
  <Navbar client:load cinemaMode={true} />
  
  <div class="relative z-10 cinema-dark min-h-screen">
    {/* Detail Hero Section */}
    <DetailHero
      title={title}
      backdrop_path={backdrop}
      poster_path={poster}
      vote_average={voteAverage}
      overview={overview}
      release_date={releaseDate}
      genres={genres}
      runtime={runtime}
      tagline={tagline}
      media_type="movie"
      playUrl={`/play/movie/${id}`}
      client:load
    />

    {/* Cast & Similar Movies Rows */}
    <div class="mt-12 space-y-12 pb-16">
      {cast.length > 0 && <CastRow cast={cast} />}
      {similar.length > 0 && <SimilarRow items={similar} media_type="movie" />}
    </div>
  </div>

  <Footer cinemaMode={true} />
</BaseLayout>
