---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/layout/Navbar';
import SleekSearchPage from '../components/search/SleekSearchPage';
import Footer from '../components/layout/Footer';
---

<BaseLayout 
  title="MoviesNest — Search and Watch Free Movies and TV Series Online" 
  description="Explore, browse, and watch premium-quality movies and TV shows for free. Stream on-demand with no subscription fees, zero ads, and instant streaming player integrations."
>
  <Navbar client:load />
  
  <main class="relative z-10 min-h-[calc(100vh-160px)] mesh-gradient-bg">
    <SleekSearchPage client:load />
  </main>

  <Footer />
</BaseLayout>
